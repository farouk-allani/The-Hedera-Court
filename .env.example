# Hedera
HEDERA_NETWORK=testnet
HEDERA_OPERATOR_ID=
HEDERA_OPERATOR_KEY=
HEDERA_COURT_TREASURY_ID=
HEDERA_VERDICT_TOKEN_ID=
HEDERA_DOCKET_TOPIC_ID=

# MongoDB
MONGODB_URI=


# Justice model
# Recommended cheap/free-tier path: get a Gemini key from Google AI Studio.
AI_PROVIDER=gemini
AI_MODEL=gemini-2.5-flash-lite
GEMINI_API_KEY=

# Optional alternates
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-5

# Optional OpenAI text/image generation. Assets already have checked-in fallbacks.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-nano
OPENAI_IMAGE_MODEL=gpt-image-1-mini

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_HEDERA_NETWORK=testnet

# WalletConnect / HashPack
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# Local-only development fallback. Leave false for bounty demos.
HEDERA_ALLOW_MOCK=false
